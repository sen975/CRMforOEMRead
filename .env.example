NODE_ENV=development
API_PORT=4100
WEB_PORT=5174

DATABASE_URL=postgresql://oem_crm:oem_crm_password@localhost:5432/oem_crm?schema=public
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_secret
JWT_ACCESS_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

OPENAI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini

STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=./storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=oem-crm
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

SMTP_SEND_RATE_PER_ACCOUNT_PER_DAY=80
SMTP_SEND_RATE_PER_ACCOUNT_PER_HOUR=20
EMAIL_REVIEW_REQUIRED=true
